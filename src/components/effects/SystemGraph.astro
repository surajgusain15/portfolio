---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  class:list={[className]}
  viewBox="0 0 800 600"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="lg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#A78BFA" stop-opacity="0.15" />
      <stop offset="100%" stop-color="#34D399" stop-opacity="0.05" />
    </linearGradient>
    <linearGradient id="lg2" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#A78BFA" stop-opacity="0" />
      <stop offset="50%" stop-color="#A78BFA" stop-opacity="0.3" />
      <stop offset="100%" stop-color="#A78BFA" stop-opacity="0" />
    </linearGradient>
  </defs>

  <!-- Background gradient -->
  <rect width="800" height="600" fill="url(#lg)" rx="16" />

  <!-- Grid -->
  <g stroke="#1E1E24" stroke-width="0.5" opacity="0.4">
    {Array.from({ length: 12 }).map((_, i) => (
      <line x1={i * 72} y1="0" x2={i * 72} y2="600" key={`vg-${i}`} />
    ))}
    {Array.from({ length: 9 }).map((_, i) => (
      <line x1="0" y1={i * 72} x2="800" y2={i * 72} key={`hg-${i}`} />
    ))}
  </g>

  <!-- Connection lines -->
  <g stroke="#A78BFA" stroke-width="1.5" opacity="0.25">
    <path d="M160 160 L320 200 L480 140 L640 180" class="animate-draw-line" />
    <path d="M160 160 L200 340 L480 380" class="animate-draw-line" style="animation-delay: 0.5s" />
    <path d="M320 200 L400 380 L600 440" class="animate-draw-line" style="animation-delay: 0.8s" />
    <path d="M640 180 L560 400 L400 380" class="animate-draw-line" style="animation-delay: 1s" />
  </g>

  <!-- Nodes -->
  <g opacity="0.9">
    <!-- API Gateway -->
    <circle cx="160" cy="160" r="32" fill="#141416" stroke="#A78BFA" stroke-width="2" />
    <text x="160" y="165" text-anchor="middle" fill="#A78BFA" font-family="monospace" font-size="9">API</text>

    <!-- Go Service -->
    <circle cx="320" cy="200" r="32" fill="#141416" stroke="#34D399" stroke-width="2" />
    <text x="320" y="205" text-anchor="middle" fill="#34D399" font-family="monospace" font-size="9">Go</text>

    <!-- K8s Cluster -->
    <circle cx="480" cy="140" r="36" fill="#141416" stroke="#A78BFA" stroke-width="2" />
    <text x="480" y="145" text-anchor="middle" fill="#A78BFA" font-family="monospace" font-size="9">K8s</text>

    <!-- Cache -->
    <circle cx="640" cy="180" r="24" fill="#141416" stroke="#FBBF24" stroke-width="2" />
    <text x="640" y="185" text-anchor="middle" fill="#FBBF24" font-family="monospace" font-size="8">DB</text>

    <!-- Auth -->
    <circle cx="200" cy="340" r="28" fill="#141416" stroke="#A78BFA" stroke-width="2" />
    <text x="200" y="345" text-anchor="middle" fill="#A78BFA" font-family="monospace" font-size="8">Auth</text>

    <!-- AI -->
    <circle cx="400" cy="380" r="32" fill="#141416" stroke="#34D399" stroke-width="2" />
    <text x="400" y="385" text-anchor="middle" fill="#34D399" font-family="monospace" font-size="9">AI</text>

    <!-- Queue -->
    <circle cx="560" cy="400" r="28" fill="#141416" stroke="#FBBF24" stroke-width="2" />
    <text x="560" y="405" text-anchor="middle" fill="#FBBF24" font-family="monospace" font-size="8">Q</text>

    <!-- Monitoring -->
    <circle cx="600" cy="440" r="28" fill="#141416" stroke="#34D399" stroke-width="2" />
    <text x="600" y="445" text-anchor="middle" fill="#34D399" font-family="monospace" font-size="7">Obs</text>
  </g>

  <!-- Pulsing dots on connections -->
  <g class="animate-pulse-slow">
    <circle cx="240" cy="178" r="3" fill="#A78BFA" />
    <circle cx="400" cy="170" r="3" fill="#A78BFA" />
    <circle cx="180" cy="250" r="3" fill="#A78BFA" />
    <circle cx="300" cy="290" r="3" fill="#34D399" />
  </g>
</svg>
