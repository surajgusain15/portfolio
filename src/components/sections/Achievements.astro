---
import ScrollReveal from "../effects/ScrollReveal.astro";

const achievements = [
  {
    icon: "dollar",
    title: "$35K/Month Cost Savings",
    subtitle: "System performance optimization",
    description: "Reduced infrastructure costs by optimizing code, cutting memory usage from 42GB to 1.5GB, and eliminating memory leaks.",
  },
  {
    icon: "cert",
    title: "ISO 22001 Certification",
    subtitle: "Quality management compliance",
    description: "Supported successful ISO 22001 certification through meticulous development practices and quality assurance.",
  },
  {
    icon: "trophy",
    title: "Hackathon Winner",
    subtitle: "Bill Payment Score Calculator",
    description: "Designed and built a Bill Payment Score Calculator in a company Hackathon, demonstrating creative problem-solving.",
  },
  {
    icon: "arch",
    title: "Full-Stack Leadership",
    subtitle: "Teams of 4–7 developers",
    description: "Led cross-functional teams in delivering MVPs, microservices, and full-stack fintech platforms from concept to deployment.",
  },
];
---

<section class="py-16 md:py-20 border-t border-border">
  <div class="container-main space-y-10">
    <ScrollReveal>
      <div class="max-w-2xl">
        <p class="font-mono text-sm text-accent tracking-widest uppercase mb-3">
          $ cat achievements.json | jq
        </p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight">
          Key achievements
        </h2>
        <p class="mt-3 text-text-secondary text-base leading-relaxed">
          Milestones that shaped my career as a systems engineer.
        </p>
      </div>
    </ScrollReveal>

    <div class="grid sm:grid-cols-2 gap-5">
      {achievements.map((item, i) => (
        <ScrollReveal delay={i * 100}>
          <div class="flex gap-4 p-5 rounded-xl border border-border bg-surface/20 hover:bg-surface/30 transition-all duration-300 group">
            <div class="shrink-0 w-10 h-10 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center text-accent group-hover:bg-accent/20 transition-colors">
              {item.icon === "dollar" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              )}
              {item.icon === "cert" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 12l2 2 4-4"/></svg>
              )}
              {item.icon === "trophy" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
              )}
              {item.icon === "arch" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
              )}
            </div>
            <div class="space-y-1">
              <h3 class="font-semibold text-text-primary">{item.title}</h3>
              <p class="font-mono text-sm text-accent">{item.subtitle}</p>
              <p class="text-sm text-text-secondary leading-relaxed">{item.description}</p>
            </div>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
