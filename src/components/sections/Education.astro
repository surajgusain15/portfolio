---
import ScrollReveal from "../effects/ScrollReveal.astro";
---

<section class="py-16 md:py-20 border-t border-border">
  <div class="container-main space-y-10">
    <ScrollReveal>
      <div class="max-w-2xl">
        <p class="font-mono text-sm text-accent tracking-widest uppercase mb-3">
          $ cat /etc/education
        </p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight">
          Education
        </h2>
      </div>
    </ScrollReveal>

    <div class="grid sm:grid-cols-2 gap-5">
      <ScrollReveal>
        <div class="p-5 rounded-xl border border-border bg-surface/20 hover:bg-surface/30 transition-colors duration-300">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center text-accent shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-text-primary">MSc Scientific Computing</h3>
              <p class="font-mono text-sm text-accent">Savitribai Phule Pune University</p>
            </div>
          </div>
          <p class="font-mono text-xs text-text-secondary">2015</p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={100}>
        <div class="p-5 rounded-xl border border-border bg-surface/20 hover:bg-surface/30 transition-colors duration-300">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center text-accent shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-text-primary">BSc Computer Science</h3>
              <p class="font-mono text-sm text-accent">Savitribai Phule Pune University</p>
            </div>
          </div>
          <p class="font-mono text-xs text-text-secondary">2013</p>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
