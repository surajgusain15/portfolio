---
import ScrollReveal from "../effects/ScrollReveal.astro";

const categories = [
  {
    label: "Languages",
    items: [
      { name: "Golang", level: "primary" },
      { name: "PHP", level: "primary" },
      { name: "Node.js", level: "primary" },
      { name: "Python", level: "intermediate" },
    ],
  },
  {
    label: "Backend Frameworks",
    items: [
      { name: "Laravel", level: "primary" },
      { name: "Next.js", level: "primary" },
      { name: "Symfony", level: "intermediate" },
      { name: "Yii", level: "intermediate" },
    ],
  },
  {
    label: "Frontend",
    items: [
      { name: "React", level: "primary" },
      { name: "Next.js", level: "primary" },
      { name: "JavaScript", level: "primary" },
    ],
  },
  {
    label: "Databases & Messaging",
    items: [
      { name: "MySQL", level: "primary" },
      { name: "PostgreSQL", level: "secondary" },
      { name: "DynamoDB", level: "primary" },
      { name: "RabbitMQ", level: "intermediate" },
      { name: "SQS", level: "primary" },
    ],
  },
  {
    label: "Cloud & AWS",
    items: [
      { name: "EC2 / RDS", level: "primary" },
      { name: "Lambda", level: "primary" },
      { name: "S3 / SNS", level: "primary" },
      { name: "API Gateway", level: "primary" },
    ],
  },
  {
    label: "DevOps & Tools",
    items: [
      { name: "Docker", level: "intermediate" },
      { name: "Git / SVN", level: "primary" },
      { name: "GitLab CI", level: "intermediate" },
      { name: "gRPC", level: "intermediate" },
    ],
  },
];

const levelColors: Record<string, string> = {
  primary: "bg-accent text-bg",
  intermediate: "bg-accent/15 text-accent",
  secondary: "bg-surface text-text-secondary border border-border",
};
---

<section id="stack" class="py-16 md:py-20 scroll-mt-16">
  <div class="container-main space-y-10">
    <ScrollReveal>
      <div class="max-w-2xl">
        <p class="font-mono text-sm text-accent tracking-widest uppercase mb-3">
          $ which stack
        </p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight">
          Tools & Technologies
        </h2>
        <p class="mt-3 text-text-secondary text-base leading-relaxed">
          Full-stack expertise across PHP, Golang, and Node.js — from
          Laravel backends to React frontends, deployed on AWS.
        </p>
      </div>
    </ScrollReveal>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {categories.map((category, i) => (
        <ScrollReveal delay={i * 100}>
          <div class="p-5 rounded-xl border border-border bg-surface/30 hover:bg-surface/50 transition-colors duration-300">
            <h3 class="font-mono text-sm text-text-secondary tracking-wider mb-5 uppercase">
              {category.label}
            </h3>
            <div class="space-y-3">
              {category.items.map((item) => (
                <div class="flex items-center justify-between">
                  <span class="font-mono text-sm text-text-primary">{item.name}</span>
                  <span class:list={["px-2 py-0.5 text-[0.625rem] font-mono rounded font-medium uppercase tracking-wider", levelColors[item.level]]}>
                    {item.level}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </ScrollReveal>
      ))}
    </div>

  </div>
</section>
