---
import SystemGraph from "../effects/SystemGraph.astro";
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<section class="relative min-h-screen flex items-center pt-20 pb-12 overflow-hidden">
  <!-- Premium background -->
  <div class="absolute inset-0 pointer-events-none">
    <svg class="w-full h-full opacity-[0.04]" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <linearGradient id="hero-grad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#A78BFA" stop-opacity="0.12" />
          <stop offset="50%" stop-color="#34D399" stop-opacity="0.06" />
          <stop offset="100%" stop-color="#A78BFA" stop-opacity="0" />
        </linearGradient>
        <radialGradient id="orb1" cx="30%" cy="30%" r="50%">
          <stop offset="0%" stop-color="#A78BFA" stop-opacity="0.08" />
          <stop offset="100%" stop-color="#A78BFA" stop-opacity="0" />
        </radialGradient>
        <radialGradient id="orb2" cx="70%" cy="70%" r="50%">
          <stop offset="0%" stop-color="#34D399" stop-opacity="0.06" />
          <stop offset="100%" stop-color="#34D399" stop-opacity="0" />
        </radialGradient>
      </defs>
      <rect width="1440" height="900" fill="url(#hero-grad)" />
      <rect width="1440" height="900" fill="url(#orb1)" />
      <rect width="1440" height="900" fill="url(#orb2)" />

      <!-- Abstract code-like lines -->
      <g stroke="#A78BFA" stroke-width="0.5" opacity="0.3">
        <path d="M100 100 l200 0 l-50 100 l200 0" fill="none" />
        <path d="M1200 200 l-150 0 l30 -80 l-200 0" fill="none" />
        <path d="M50 500 l300 0 l-80 60 l200 0" fill="none" />
        <path d="M1100 600 l-200 0 l60 -100 l-150 0" fill="none" />
      </g>

      <!-- Circuit nodes -->
      <g fill="#A78BFA" opacity="0.15">
        <circle cx="300" cy="150" r="3" />
        <circle cx="450" cy="200" r="2" />
        <circle cx="1200" cy="250" r="3" />
        <circle cx="1050" cy="170" r="2" />
        <circle cx="200" cy="550" r="2.5" />
        <circle cx="1150" cy="650" r="2" />
      </g>
    </svg>
  </div>

  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background: radial-gradient(circle at 50% 50%, #A78BFA 0%, transparent 70%)"
  />

  <!-- Cursor glow follower -->
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.04]"
    data-cursor-glow
    style="background: radial-gradient(600px circle at 50% 50%, #A78BFA, transparent 60%)"
  />

  <div class="container-main relative w-full">
    <div class="grid lg:grid-cols-2 gap-10 items-center">
      <div class="space-y-6">
        <div class="space-y-3">
          <p class="font-mono text-sm text-accent tracking-widest uppercase animate-fade-in">
            Principal Software Engineer &bull; Full-Stack &bull; Fintech
          </p>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight">
            I build systems<br />
            <span class="gradient-text">that scale.</span>
          </h1>

          <p class="text-base text-text-secondary leading-relaxed max-w-lg font-mono" data-typewriter>
            PHP, Golang, Node.js. Architecting full-stack fintech solutions —
            from payment flows to microservices — processing millions of
            transactions with reliability and performance.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a
            href={`${base}#projects`}
            class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-bg font-semibold rounded-lg hover:brightness-110 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 glow-ring text-sm"
          >
            View Projects
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3v10m0 0l4-4m-4 4l-4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a
            href={`${base}#contact`}
            class="inline-flex items-center gap-2 px-6 py-3 border border-border text-text-primary font-semibold rounded-lg hover:bg-surface/50 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 text-sm"
          >
            Get in Touch
          </a>
        </div>

        <div class="flex items-center gap-4 text-sm text-text-secondary font-mono">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-accent-alt animate-pulse" />
            <span class="text-xs">Available for consulting</span>
          </div>
          <div class="hidden sm:flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <span class="text-xs">UTC+5:30</span>
          </div>
        </div>
      </div>

      <div class="hidden lg:block">
        <SystemGraph class="w-full h-auto animate-fade-in" />
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-text-secondary animate-pulse-slow">
    <span class="font-mono text-[0.625rem] tracking-widest uppercase">Scroll</span>
    <svg width="14" height="20" viewBox="0 0 16 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="14" height="22" rx="7"/><circle cx="8" cy="8" r="2" fill="currentColor"/></svg>
  </div>
</section>

<script>
  // Cursor glow follower
  const glow = document.querySelector("[data-cursor-glow]");
  if (glow) {
    const hero = glow.closest("section");
    hero?.addEventListener("mousemove", (e) => {
      const rect = hero.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      glow.style.background = `radial-gradient(600px circle at ${x}% ${y}%, #A78BFA, transparent 60%)`;
    });
  }
</script>
