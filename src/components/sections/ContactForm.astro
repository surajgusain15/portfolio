---
import ScrollReveal from "../effects/ScrollReveal.astro";
---

<section id="contact" class="py-16 md:py-20 border-t border-border scroll-mt-16">
  <div class="container-main space-y-10">
    <ScrollReveal>
      <div class="max-w-2xl">
        <p class="font-mono text-sm text-accent tracking-widest uppercase mb-3">
          $ nc -v contact 443
        </p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight">
          Work with me
        </h2>
        <p class="mt-3 text-text-secondary text-base leading-relaxed">
          I respond within 24 hours. No agencies, no recruiters — just direct
          conversations about your systems challenges.
        </p>
      </div>
    </ScrollReveal>

    <div class="grid lg:grid-cols-2 gap-6 items-start">
      <!-- Contact form -->
      <ScrollReveal>
        <form
          class="space-y-5"
          data-contact-form
        >
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="space-y-2">
              <label for="name" class="block font-mono text-xs text-text-secondary uppercase tracking-wider">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-surface/30 border border-border rounded-lg font-mono text-sm text-text-primary placeholder:text-text-secondary/40 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/30 transition-colors"
                placeholder="Your name"
              />
            </div>
            <div class="space-y-2">
              <label for="email" class="block font-mono text-xs text-text-secondary uppercase tracking-wider">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-surface/30 border border-border rounded-lg font-mono text-sm text-text-primary placeholder:text-text-secondary/40 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/30 transition-colors"
                placeholder="you@company.com"
              />
            </div>
          </div>
          <div class="space-y-2">
            <label for="message" class="block font-mono text-xs text-text-secondary uppercase tracking-wider">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows={5}
              class="w-full px-4 py-3 bg-surface/30 border border-border rounded-lg font-mono text-sm text-text-primary placeholder:text-text-secondary/40 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/30 transition-colors resize-y min-h-[120px]"
              placeholder="Tell me about your project or challenge..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent text-bg font-semibold rounded-lg hover:brightness-110 transition-all duration-200 glow-ring font-mono text-sm"
            data-submit-btn
          >
            Send message
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </ScrollReveal>

      <!-- Direct contact options -->
      <ScrollReveal delay={200}>
        <div class="space-y-6">
          <div class="p-5 rounded-xl border border-border bg-surface/20">
            <p class="font-mono text-sm text-accent mb-1">Prefer direct email?</p>
            <a
              href="mailto:suraj.gusain15@gmail.com"
              class="text-lg font-mono text-text-primary hover:text-accent transition-colors"
            >
              suraj.gusain15@gmail.com
            </a>
            <p class="mt-2 text-sm text-text-secondary font-mono">
              Response time: typically within 4 hours
            </p>
          </div>

          <div class="p-5 rounded-xl border border-border bg-surface/20">
            <p class="font-mono text-sm text-accent mb-1">Want a quick chat?</p>
            <a
              href="https://calendly.com/suraj-gusain15/30min"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-lg font-mono text-text-primary hover:text-accent transition-colors"
            >
              Book a 30-min call
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </a>
            <p class="mt-2 text-sm text-text-secondary font-mono">
              No commitment, just a conversation
            </p>
          </div>

          <div class="p-5 rounded-xl border border-border bg-surface/20">
            <p class="font-mono text-sm text-accent mb-1">Availability</p>
            <div class="flex items-center gap-2 mt-2">
              <span class="w-2 h-2 rounded-full bg-accent-alt animate-pulse" />
              <span class="font-mono text-sm text-text-primary">Open for consulting (remote)</span>
            </div>
            <p class="mt-1 text-sm text-text-secondary font-mono">
              Based in India · UTC+5:30
            </p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector("[data-contact-form]");

  if (form instanceof HTMLFormElement) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const name = document.getElementById("name")?.value || "";
      const email = document.getElementById("email")?.value || "";
      const message = document.getElementById("message")?.value || "";
      const a = document.createElement("a");
      a.href = `mailto:suraj.gusain15@gmail.com?subject=${encodeURIComponent("Portfolio inquiry from " + name)}&body=${encodeURIComponent("Name: " + name + "\nEmail: " + email + "\n\n" + message)}`;
      a.click();
    });
  }
</script>
