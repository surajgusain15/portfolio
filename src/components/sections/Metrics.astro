---
import ScrollReveal from "../effects/ScrollReveal.astro";
import CountUp from "../effects/CountUp.astro";
---

<section class="py-16 md:py-20 relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.02]"
    style="background: radial-gradient(circle at 30% 50%, #A78BFA 0%, transparent 60%), radial-gradient(circle at 70% 50%, #34D399 0%, transparent 60%)"
  />

  <div class="container-main relative">
    <ScrollReveal>
      <div class="max-w-2xl mb-10">
        <p class="font-mono text-sm text-accent tracking-widest uppercase mb-3">
          $ cat /proc/impact
        </p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight">
          By the numbers
        </h2>
        <p class="mt-3 text-text-secondary text-base leading-relaxed">
          Metrics from production systems I've built and operated.
        </p>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      {[
        { value: 8, suffix: "+", label: "Years of software engineering", subtitle: "Fintech, full-stack, cloud" },
        { value: 35, prefix: "$", suffix: "K/mo", label: "Infrastructure cost saved", subtitle: "Through code & memory optimization" },
        { value: 7, suffix: "+", label: "Team size led", subtitle: "Lead developer across projects" },
        { value: 100, suffix: "%", label: "Timely project delivery", subtitle: "Across all roles and teams" },
      ].map((metric, i) => (
        <ScrollReveal delay={i * 120}>
          <div class="text-center">
            <p class="text-4xl md:text-5xl lg:text-6xl font-bold font-accent gradient-text leading-none">
              <CountUp value={metric.value} suffix={metric.suffix} decimals={metric.decimals ?? 0} />
            </p>
            <p class="mt-3 font-mono text-sm text-text-primary font-medium">
              {metric.label}
            </p>
            <p class="mt-1 text-xs text-text-secondary font-mono">
              {metric.subtitle}
            </p>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
