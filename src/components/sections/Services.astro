---
import ScrollReveal from "../effects/ScrollReveal.astro";

const services = [
  {
    title: "Full-Stack Development",
    description: "End-to-end application development across PHP (Laravel), Golang, and Node.js. From payment systems to microservices architecture.",
    cta: "Tech stack review",
    icon: "arch",
  },
  {
    title: "Cloud & AWS Architecture",
    description: "Design and migration of workloads on AWS (EC2, Lambda, RDS, SQS, SNS, API Gateway). Cost optimization and serverless architecture.",
    cta: "Cloud audit",
    icon: "k8s",
  },
  {
    title: "Performance & Cost Optimization",
    description: "Memory leak diagnosis, code optimization, infrastructure cost reduction. Proven track record of $35K/month savings.",
    cta: "Performance review",
    icon: "perf",
  },
  {
    title: "Technical Advisory",
    description: "Fractional CTO/architect for fintech and SaaS startups. Roadmap planning, team leadership, and system design consultation.",
    cta: "Advisory session",
    icon: "advise",
  },
];
---

<section id="services" class="py-16 md:py-20">
  <div class="container-main space-y-10">
    <ScrollReveal>
      <div class="max-w-2xl">
        <p class="font-mono text-sm text-accent tracking-widest uppercase mb-3">
          $ what i offer
        </p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight">
          How I can help
        </h2>
        <p class="mt-3 text-text-secondary text-base leading-relaxed">
          From full-stack development to cloud architecture — I help fintech
          and SaaS teams build systems that perform.
        </p>
      </div>
    </ScrollReveal>

    <div class="grid sm:grid-cols-2 gap-5">
      {services.map((s, i) => (
        <ScrollReveal delay={i * 100}>
          <div class="group p-5 rounded-xl border border-border bg-surface/20 hover:bg-surface/30 hover:border-accent/20 transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center text-accent group-hover:bg-accent/20 transition-colors">
                {s.icon === "arch" && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
                )}
                {s.icon === "k8s" && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
                )}
                {s.icon === "perf" && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                )}
                {s.icon === "advise" && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                )}
              </div>
              <div class="space-y-2">
                <h3 class="font-semibold text-text-primary">{s.title}</h3>
                <p class="text-sm text-text-secondary leading-relaxed">{s.description}</p>
                <span class="inline-block font-mono text-xs text-accent group-hover:text-accent/80 transition-colors">
                  {s.cta} →
                </span>
              </div>
            </div>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
