---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/shared/Navigation.astro";
import Footer from "../../components/shared/Footer.astro";
import TerminalWindow from "../../components/ui/TerminalWindow.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id.replace(/\.mdx$/, "") },
    props: { project },
  }));
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const cleanSlug = project.id.replace(/\.mdx$/, "");
const { Content } = await project.render();
---

<Layout
  title={`${project.data.title} — Suraj Gusain`}
  description={project.data.description}
  ogType="article"
  breadcrumbs={[
    { name: "Home", path: "/" },
    { name: "Projects", path: "/projects" },
    { name: project.data.title, path: `/projects/${cleanSlug}` },
  ]}
>
  <Navigation />
  <main id="main-content" class="pt-24 pb-16">
    <article class="container-main max-w-3xl space-y-12">
      <div class="space-y-4">
        <a
          href={`${base}projects`}
          class="inline-flex items-center gap-1 font-mono text-sm text-text-secondary hover:text-text-primary transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M10 12L6 8l4-4" />
          </svg>
          Back to projects
        </a>

        <h1 class="text-3xl md:text-5xl font-bold tracking-tight">
          {project.data.title}
        </h1>

        <TerminalWindow title={project.data.subtitle}>
          <p class="text-sm text-text-secondary leading-relaxed">
            {project.data.description}
          </p>
          <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-border">
            {project.data.tags.map((tag) => (
              <span class="px-2 py-1 text-[0.6875rem] font-mono bg-surface/50 text-text-secondary rounded">
                {tag}
              </span>
            ))}
          </div>
        </TerminalWindow>
      </div>

      <div class="prose-custom">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .prose-custom {
    color: var(--color-text-secondary);
    line-height: 1.8;
    font-size: 0.9375rem;
  }

  .prose-custom :global(h2) {
    color: var(--color-text-primary);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .prose-custom :global(h3) {
    color: var(--color-text-primary);
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose-custom :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose-custom :global(code) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-surface);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .prose-custom :global(pre) {
    background: #0D0D0F;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose-custom :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }

  .prose-custom :global(ul) {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }

  .prose-custom :global(li) {
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.5rem;
  }

  .prose-custom :global(li::before) {
    content: "▹";
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }
</style>
